#!/bin/bash

TOUCH_FILE_PATH="/Users/Shared/.com.github.munkireport.run"
LAUNCHD="com.github.munkireport.runner"
LAUNCHD_PLIST="/Library/LaunchDaemons/${LAUNCHD}.plist"
SUBMIT_SCRIPT="/usr/local/munkireport/munkireport-runner"

/bin/rm -f "$TOUCH_FILE_PATH"
/usr/bin/touch "$TOUCH_FILE_PATH"

if [[ -f "$LAUNCHD_PLIST" ]]; then
  if ! /bin/launchctl list | /usr/bin/grep -q "$LAUNCHD"; then
    /bin/launchctl bootstrap system "$LAUNCHD_PLIST" 2>/dev/null || \
    /bin/launchctl load -w "$LAUNCHD_PLIST" 2>/dev/null || true
  fi
  if ! /bin/launchctl list | /usr/bin/grep -q "$LAUNCHD"; then
    [[ -x "$SUBMIT_SCRIPT" ]] && "$SUBMIT_SCRIPT"
  fi
else
  [[ -x "$SUBMIT_SCRIPT" ]] && "$SUBMIT_SCRIPT"
fi
